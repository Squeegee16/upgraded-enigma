# Ham Radio Application - Environment Variables
# ==============================================

# Flask Application Settings
FLASK_ENV=development
FLASK_DEBUG=1

# SECRET_KEY is now auto-generated if not provided
# Uncomment and set your own key for production:
# SECRET_KEY=your-secure-key-here
# 
# To generate a secure key:
# python3 -c 'import secrets; print(secrets.token_hex(32))'

# Database Configuration
DATABASE_URL=sqlite:////data/db/ham_radio.db

# ============================================================
# Hardware Device Configuration
# ============================================================

# Set to false to use real hardware
USE_MOCK_DEVICES=false

# RTL-SDR device index (0 = first dongle)
SDR_DEVICE_INDEX=0
SDR_SAMPLE_RATE=2048000

# GPS serial port (check: ls -l /dev/ttyUSB*)
GPS_SERIAL_PORT=/dev/ttyUSB0
GPS_BAUD_RATE=9600

# Radio CAT port
RADIO_PORT=/dev/ttyUSB1
RADIO_BAUD_RATE=38400
RADIO_MODEL=1035

# SSL/TLS Configuration
USE_SSL=true
SSL_CERT=/data/certs/cert.pem
SSL_KEY=/data/certs/key.pem

# Server Configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Callsign Validation
VALIDATE_CALLSIGNS=false
CALLSIGN_FILE=/data/callsigns/callsigns.txt

# Timezone
TZ=UTC

# Backup Configuration
BACKUP_INTERVAL=86400
BACKUP_RETENTION=7
