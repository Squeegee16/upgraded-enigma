# Ham Radio Application - Environment Variables
# ==============================================
# Copy this file to .env and customize for your deployment
# Usage: cp .env.example .env

# =================================================================
# Flask Application Settings
# =================================================================
FLASK_ENV=production
FLASK_DEBUG=True

# Secret key for session encryption
# IMPORTANT: Generate a secure random key for production!
# Generate with: python -c 'import secrets; print(secrets.token_hex(32))'
SECRET_KEY=change-this-to-a-secure-random-key-in-production

# =================================================================
# Database Configuration
# =================================================================
# SQLite database path (inside container)
DATABASE_URL=sqlite:////data/db/ham_radio.db

# =================================================================
# Device Configuration
# =================================================================
# Set to 'false' to use real hardware devices
USE_MOCK_DEVICES=True

# GPS Configuration
GPS_SERIAL_PORT=/dev/ttyUSB0
GPS_BAUD_RATE=9600

# Radio Configuration (Hamlib)
# Model 1035 = Yaesu FT-891
# See: http://hamlib.sourceforge.net/supported-radios.html
RADIO_MODEL=1035
RADIO_PORT=/dev/ttyUSB1
RADIO_BAUD_RATE=38400

# RTL-SDR Configuration
SDR_DEVICE_INDEX=0
SDR_SAMPLE_RATE=2048000

# =================================================================
# SSL/TLS Configuration
# =================================================================
USE_SSL=true
SSL_CERT=/data/certs/cert.pem
SSL_KEY=/data/certs/key.pem

# =================================================================
# Server Configuration
# =================================================================
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# =================================================================
# Callsign Validation
# =================================================================
# Enable to validate callsigns against a known list
VALIDATE_CALLSIGNS=True
CALLSIGN_FILE=/data/callsigns/callsigns.txt

# =================================================================
# Timezone
# =================================================================
TZ=UTC

# =================================================================
# Backup Configuration
# =================================================================
# Backup interval in seconds (86400 = 24 hours)
BACKUP_INTERVAL=86400

# Number of days to retain backups
BACKUP_RETENTION=7

# =================================================================
# Build Arguments (for Docker build)
# =================================================================
BUILD_DATE=2024-04-15
VCS_REF=main
